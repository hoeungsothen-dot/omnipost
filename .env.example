# ─── Supabase (required for real auth + database) ───────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Backend API (optional — for server-side publishing) ─────────────────────
VITE_BACKEND_URL=https://your-backend.com

# ─── Facebook / Instagram ────────────────────────────────────────────────────
VITE_FB_APP_ID=your-facebook-app-id

# ─── Google / YouTube ────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── TikTok ──────────────────────────────────────────────────────────────────
VITE_TIKTOK_CLIENT_KEY=your-tiktok-client-key

# ─── LinkedIn ────────────────────────────────────────────────────────────────
VITE_LINKEDIN_CLIENT_ID=your-linkedin-client-id

# ─── Twitter / X ─────────────────────────────────────────────────────────────
VITE_TWITTER_CLIENT_ID=your-twitter-client-id

# ─── Telegram ────────────────────────────────────────────────────────────────
VITE_TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─── Redirect base URL (your deployed domain) ────────────────────────────────
VITE_APP_URL=https://omnipost.yourdomain.com
