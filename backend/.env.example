# ─── Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/omnipost

# ─── Redis (job queue) ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_at_least_64_chars

# ─── AI ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Media Storage (Cloudinary) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Facebook / Instagram (Meta) ─────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=any_random_string_you_choose

# ─── Google / YouTube ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── TikTok ───────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── LinkedIn ─────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Telegram & Website configured per-workspace in UI ────────────────────
